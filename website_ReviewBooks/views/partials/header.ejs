<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | ReviewBooks</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/pages.css">
  <script src="/js/main.js" defer></script>
  <script src="/js/popup.js" defer></script>
  <script src="/js/validation.js" defer></script>
  <script src="/js/comments.js" defer></script>
</head>
<body>
<a class="skip-link" href="#main-content">Bỏ qua đến nội dung</a>
<header class="site-header">
  <a class="logo-pill" href="/">
    <img src="/images/logo.svg" alt="">
    <span class="logo-text">ReviewBooks</span>
  </a>

  <button class="menu-toggle" type="button" data-menu-toggle aria-label="Mở menu">☰</button>

  <nav class="main-nav" data-main-menu>
    <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Trang chủ</a>
    <a class="<%= currentPath.startsWith('/books') ? 'active' : '' %>" href="/books">Khám phá</a>
    <a class="<%= currentPath === '/reviews' ? 'active' : '' %>" href="/reviews">Bình luận</a>
    <a class="<%= currentPath === '/contact' ? 'active' : '' %>" href="/contact">Liên hệ</a>
  </nav>

  <div class="header-actions">
    <form class="quick-search" action="/books" method="GET">
      <input type="search" name="search" placeholder="Tìm sách" aria-label="Tìm sách">
      <button type="submit" aria-label="Tìm kiếm">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2"/>
          <line x1="15.3" y1="15.3" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </form>
    <% if (currentUser) { %>
      <% if (currentUser.role === 'admin') { %>
        <a class="small-button" href="/admin/dashboard">Quản trị</a>
      <% } %>
      <div class="account-menu" data-account-menu>
        <button class="small-button account-trigger" type="button" data-account-trigger aria-haspopup="true" aria-expanded="false">
          <span><%= currentUser.username %></span>
          <svg class="account-caret" viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
            <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="account-dropdown" data-account-dropdown>
          <div class="account-dropdown-inner">
            <a href="/account">Tài khoản</a>
            <form action="/logout" method="POST">
              <button type="submit">Đăng xuất</button>
            </form>
          </div>
        </div>
      </div>
    <% } else { %>
      <a class="auth-link auth-link-secondary" href="/login">Đăng nhập</a>
      <a class="auth-link auth-link-primary" href="/register">Đăng ký</a>
    <% } %>
  </div>
</header>
<main id="main-content">
  <div class="container">
    <%- include('flash') %>
  </div>
