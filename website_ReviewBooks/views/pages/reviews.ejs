<%- include('../partials/header') %>

<div class="container">
<div class="section-heading">
  <h1>Tất cả bình luận</h1>
  <p>Những cảm nhận mới nhất từ cộng đồng độc giả ReviewBooks.</p>
</div>

<form class="filter-bar" method="GET" action="/reviews">
  <div class="field" style="margin-bottom:0;">
    <label for="search">Tìm kiếm</label>
    <input type="search" id="search" name="search" placeholder="Tên người đánh giá, tên sách, nội dung..." value="<%= search %>">
  </div>
  <div class="field" style="margin-bottom:0;">
    <label for="sort">Sắp xếp</label>
    <select id="sort" name="sort">
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
      <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
      <option value="rating_high" <%= sort === 'rating_high' ? 'selected' : '' %>>Đánh giá cao</option>
      <option value="rating_low" <%= sort === 'rating_low' ? 'selected' : '' %>>Đánh giá thấp</option>
    </select>
  </div>
  <button class="btn btn-primary" type="submit">Lọc</button>
</form>

<% if (reviews.length === 0) { %>
  <div class="empty-state">Không tìm thấy bình luận phù hợp.</div>
<% } else { %>
  <div class="card card-pad">
    <% reviews.forEach((review) => { %>
      <div class="reviews-feed-item">
        <img src="<%= review.book_cover_image %>" alt="Bìa sách <%= review.book_title %>">
        <div>
          <div class="review-item-head">
            <div>
              <a href="/books/<%= review.book_id %>#reviews"><strong><%= review.book_title %></strong></a>
              <span class="review-item-date"> &middot; <%= review.book_author %></span>
            </div>
            <%- include('../partials/star-rating-display', { value: review.rating }) %>
          </div>
          <div class="review-item-head">
            <span class="review-item-name">
              <%= review.username || review.name %>
              <span class="review-item-email">(<%= review.email %>)</span>
            </span>
            <span class="review-item-date"><%= new Date(review.created_at).toLocaleTimeString('vi-VN') %> &middot; <%= new Date(review.created_at).toLocaleDateString('vi-VN') %></span>
          </div>
          <p style="margin-top: var(--space-2); margin-bottom: 0;"><%= review.content %></p>
        </div>
      </div>
    <% }) %>
  </div>

  <%- include('../partials/pagination') %>
<% } %>
</div>

<%- include('../partials/footer') %>
