<%- include('../partials/header') %>

<div class="container">
<div class="section-heading">
  <h1>Giới thiệu &amp; Liên hệ</h1>
</div>

<div class="contact-grid">
  <div>
    <div class="card card-pad">
      <h3>Về ReviewBooks</h3>
      <p>ReviewBooks là dự án bài tập lớn môn Lập trình Web và Ứng dụng Di động, xây dựng một không gian để độc giả khám phá sách hay và chia sẻ cảm nhận thật của mình.</p>

      <div class="contact-info-item">
        <div class="contact-info-icon">@</div>
        <div>
          <strong>Email</strong>
          <p style="margin:0;">contact@reviewbooks.local</p>
        </div>
      </div>
      <div class="contact-info-item">
        <div class="contact-info-icon">&#9742;</div>
        <div>
          <strong>Điện thoại</strong>
          <p style="margin:0;">0123 456 789</p>
        </div>
      </div>
      <div class="contact-info-item">
        <div class="contact-info-icon">&#9733;</div>
        <div>
          <strong>Địa chỉ</strong>
          <p style="margin:0;">Đại học Bách Khoa Hà Nội <br> <small>Số 1 Đại Cồ Việt, Hà Nội, Việt Nam</small></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card card-pad">
    <h3>Gửi ý kiến của bạn</h3>

    <% if (sent) { %>
      <div class="alert alert-success">Cảm ơn bạn đã gửi ý kiến! Chúng tôi sẽ phản hồi sớm nhất có thể.</div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/contact" data-validate-form novalidate>
      <div class="form-row form-row-2">
        <div class="field">
          <label for="name">Họ tên</label>
          <input type="text" id="name" name="name" required minlength="2" maxlength="100" value="<%= formData.name %>">
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required maxlength="120" value="<%= formData.email %>">
        </div>
      </div>
      <div class="field">
        <label for="subject">Tiêu đề</label>
        <input type="text" id="subject" name="subject" maxlength="200" placeholder="Góp ý website">
      </div>
      <div class="field">
        <label for="message">Nội dung</label>
        <textarea id="message" name="message" required minlength="5" maxlength="3000" placeholder="Chia sẻ ý kiến của bạn..."></textarea>
      </div>
      <button class="btn btn-primary" type="submit">Gửi ý kiến</button>
    </form>
  </div>
</div>
</div>

<%- include('../partials/footer') %>
