<%- include('../partials/admin-header') %>

<h1>Sửa người dùng</h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="card card-pad">
  <form method="POST" action="/admin/users/<%= user.id %>/edit" data-validate-form novalidate>
    <div class="form-row form-row-2">
      <div class="field">
        <label for="username">Tên đăng nhập</label>
        <input type="text" id="username" name="username" required minlength="3" maxlength="50" pattern="[a-zA-Z0-9_]+" value="<%= user.username || '' %>">
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required maxlength="120" value="<%= user.email || '' %>">
      </div>
    </div>

    <div class="form-row form-row-2">
      <div class="field">
        <label for="password">Mật khẩu (để trống nếu không đổi)</label>
        <input type="password" id="password" name="password" minlength="6">
      </div>
      <div class="field">
        <label for="role">Vai trò</label>
        <select id="role" name="role">
          <option value="user" <%= user.role !== 'admin' ? 'selected' : '' %>>Người dùng</option>
          <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Quản trị viên</option>
        </select>
      </div>
    </div>

    <div class="form-actions">
      <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
      <a class="btn btn-outline" href="/admin/users">Hủy</a>
    </div>
  </form>
</div>

<%- include('../partials/admin-footer') %>
