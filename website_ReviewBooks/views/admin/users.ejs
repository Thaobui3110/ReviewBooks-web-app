<%- include('../partials/admin-header') %>

<div class="admin-toolbar">
  <h1 style="margin:0;">Quản lý người dùng <span class="badge badge-muted"><%= pagination.totalItems %> tài khoản</span></h1>
</div>

<div class="card card-pad" style="margin-bottom: var(--space-6);">
  <h3>Tạo tài khoản mới</h3>
  <form method="POST" action="/admin/users/create" class="admin-filter-bar create-user-grid" data-validate-form novalidate>
    <div class="field">
      <label for="new_username">Tên đăng nhập</label>
      <input type="text" id="new_username" name="username" required minlength="3" maxlength="50" pattern="[a-zA-Z0-9_]+">
    </div>
    <div class="field">
      <label for="new_email">Email</label>
      <input type="email" id="new_email" name="email" required maxlength="120">
    </div>
    <div class="field">
      <label for="new_role">Vai trò</label>
      <select id="new_role" name="role">
        <option value="user">Người dùng</option>
        <option value="admin">Quản trị viên</option>
      </select>
    </div>
    <div class="field">
      <label for="new_password">Mật khẩu</label>
      <input type="password" id="new_password" name="password" required minlength="6">
    </div>
    <div class="filter-actions">
      <button class="btn btn-primary" type="submit">+ Tạo</button>
    </div>
  </form>
</div>

<form class="admin-filter-bar cols-2" method="GET" action="/admin/users">
  <div class="field">
    <label for="search">Tìm theo tên đăng nhập / email</label>
    <input type="search" id="search" name="search" placeholder="Nhập từ khoá..." value="<%= search %>">
  </div>
  <div class="field">
    <label for="role">Lọc theo vai trò</label>
    <select id="role" name="role">
      <option value="">-- Tất cả vai trò --</option>
      <option value="user" <%= role === 'user' ? 'selected' : '' %>>Người dùng</option>
      <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>Quản trị viên</option>
    </select>
  </div>
  <div class="filter-actions">
    <button class="btn btn-primary" type="submit">Tìm</button>
    <a class="btn btn-outline" href="/admin/users">Xóa lọc</a>
  </div>
</form>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr><th>ID</th><th>Tên đăng nhập</th><th>Email</th><th>Vai trò</th><th>Trạng thái</th><th>Tham gia</th><th>Thao tác</th></tr>
    </thead>
    <tbody>
      <% users.forEach((user) => { %>
        <tr>
          <td>#<%= user.id %></td>
          <td><%= user.username %></td>
          <td><%= user.email %></td>
          <td><span class="badge <%= user.role === 'admin' ? '' : 'badge-muted' %>"><%= user.role === 'admin' ? 'Quản trị viên' : 'Người dùng' %></span></td>
          <td><span class="status-dot <%= user.is_online ? 'is-online' : '' %>"><%= user.is_online ? 'Đang online' : 'Ngoại tuyến' %></span></td>
          <td><%= new Date(user.created_at).toLocaleDateString('vi-VN') %></td>
          <td>
            <div class="row-actions">
              <a class="btn btn-outline btn-sm" href="/admin/users/<%= user.id %>/edit">Sửa</a>
              <% if (user.role !== 'admin') { %>
                <form class="inline-form" method="POST" action="/admin/users/<%= user.id %>/delete" data-confirm="Xóa người dùng này?">
                  <button class="btn btn-danger btn-sm" type="submit">Xóa</button>
                </form>
              <% } %>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination') %>

<%- include('../partials/admin-footer') %>
