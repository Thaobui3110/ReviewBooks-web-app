<%- include('../partials/admin-header') %>

<h1>Bình luận <span class="badge badge-muted"><%= pagination.totalItems %> bình luận</span></h1>

<form class="admin-filter-bar cols-3" method="GET" action="/admin/comments">
  <div class="field">
    <label for="search">Tìm theo sách / người dùng / nội dung</label>
    <input type="search" id="search" name="search" placeholder="Nhập từ khoá..." value="<%= search %>">
  </div>
  <div class="field">
    <label for="sort">Sắp xếp</label>
    <select id="sort" name="sort">
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
      <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
      <option value="rating_high" <%= sort === 'rating_high' ? 'selected' : '' %>>Điểm cao nhất</option>
      <option value="rating_low" <%= sort === 'rating_low' ? 'selected' : '' %>>Điểm thấp nhất</option>
    </select>
  </div>
  <div class="filter-actions">
    <button class="btn btn-primary" type="submit">Tìm</button>
    <a class="btn btn-outline" href="/admin/comments">Xóa lọc</a>
  </div>
</form>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr><th>Sách</th><th>Người dùng</th><th>Nội dung</th><th>Điểm</th><th>Ngày</th><th>Thao tác</th></tr>
    </thead>
    <tbody>
      <% comments.forEach((comment) => { %>
        <tr>
          <td class="wrap"><%= comment.book_title %></td>
          <td><%= comment.username || comment.name %><br><span class="review-item-date"><%= comment.email %></span></td>
          <td class="wrap"><%= comment.content %></td>
          <td><%- include('../partials/star-rating-display', { value: comment.rating }) %></td>
          <td><%= new Date(comment.created_at).toLocaleDateString('vi-VN') %></td>
          <td>
            <form method="POST" action="/admin/comments/<%= comment.id %>/delete" data-confirm="Xóa bình luận này?">
              <button class="btn btn-danger btn-sm" type="submit">Xóa</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination') %>

<%- include('../partials/admin-footer') %>
