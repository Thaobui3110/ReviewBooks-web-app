<%- include('../partials/admin-header') %>

<div class="admin-toolbar">
  <h1 style="margin:0;">Quản lý sách <span class="badge badge-muted"><%= pagination.totalItems %> sách</span></h1>
  <a class="btn btn-primary" href="/admin/books/create">+ Thêm sách</a>
</div>

<form class="admin-filter-bar cols-4" method="GET" action="/admin/books">
  <div class="field">
    <label for="search">Tìm theo tên sách / tác giả</label>
    <input type="search" id="search" name="search" placeholder="Nhập từ khoá..." value="<%= search %>">
  </div>
  <div class="field">
    <label for="category">Thể loại</label>
    <select id="category" name="category">
      <option value="">-- Tất cả thể loại --</option>
      <% categories.forEach((cat) => { %>
        <option value="<%= cat.name %>" <%= category === cat.name ? 'selected' : '' %>><%= cat.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="field">
    <label for="sort">Sắp xếp</label>
    <select id="sort" name="sort">
      <option value="updated" <%= sort === 'updated' ? 'selected' : '' %>>Cập nhật gần đây</option>
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Mới thêm</option>
      <option value="title" <%= sort === 'title' ? 'selected' : '' %>>Tên A-Z</option>
      <option value="author" <%= sort === 'author' ? 'selected' : '' %>>Tác giả A-Z</option>
    </select>
  </div>
  <div class="filter-actions">
    <button class="btn btn-primary" type="submit">Lọc</button>
    <a class="btn btn-outline" href="/admin/books">Xóa lọc</a>
  </div>
</form>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>ID</th><th>Tên sách</th><th>Tác giả</th><th>Thể loại</th><th>Cập nhật</th><th>Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <% books.forEach((book) => { %>
        <tr>
          <td>#<%= book.id %></td>
          <td class="wrap"><%= book.title %></td>
          <td><%= book.author %></td>
          <td>
            <% (book.tags || []).forEach((tag) => { %>
              <span class="badge badge-muted"><%= tag.name %></span>
            <% }) %>
          </td>
          <td><%= new Date(book.updated_at).toLocaleDateString('vi-VN') %></td>
          <td>
            <div class="row-actions">
              <a class="btn btn-outline btn-sm" href="/admin/books/<%= book.id %>/edit">Sửa</a>
              <form class="inline-form" method="POST" action="/admin/books/<%= book.id %>/delete" data-confirm="Xóa sách này và toàn bộ bình luận liên quan?">
                <button class="btn btn-danger btn-sm" type="submit">Xóa</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination') %>

<%- include('../partials/admin-footer') %>
